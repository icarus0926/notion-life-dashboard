# ===== 天罡日程管理系统 环境变量 =====
# 复制本文件为 .env 并逐项填写(.env 不要提交/外传)

# Notion Internal Integration Token
# 获取: https://www.notion.so/my-integrations 新建集成 → 复制 secret(ntn_ 开头)
# 注意: 建好的 6 个数据库都要「添加连接」共享给这个集成,否则接口全部 404
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 网页访问口令(登录门),自己设一个强口令
DASH_PASSWORD=change-me

# 服务端口
PORT=8787

# ===== 6 个 Notion 数据库的 ID =====
# 获取: 浏览器打开数据库整页,URL 里 notion.so/ 之后、? 之前的 32 位十六进制串
# 各库的属性名/类型必须与 docs/notion-schema.json 完全一致(中文属性名逐字匹配)
DB_GOALS=          # 年度目标
DB_GROWTH_POOL=    # 个人成长任务池
DB_WORK_POOL=      # 主业任务池
DB_MONTHLY=        # 月度计划
DB_WEEKLY=         # 周计划
DB_DAILY=          # 每日执行
